{
  "name": "streetlight",
  "version": "0.0.0",
  "private": true,
  "description": "Open-source REAPER agent kernel. Step 0: kernel types only.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --noEmit || tsc -b",
    "test": "vitest run",
    "clean": "tsc -b --clean",
    "setup": "node scripts/setup.mjs",
    "setup:beginner": "node scripts/install.mjs",
    "check:manifest": "npm run build --silent && node scripts/manifest-alignment.mjs",
    "check:template-authoring": "npm run build --silent && node scripts/template-authoring-lint.mjs",
    "gen:error-codes": "node scripts/error-codes.mjs generate",
    "check:error-codes-fresh": "node scripts/error-codes.mjs check"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
